<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  <style>
    :root {
      color-scheme: light;
      --paper: #ffffff;
      --bg: #ffffff;
      --ink: #000000;
      --muted: #4b5563;
      --line: #d1d5db;
      --accent: #0f766e;
      --accent-soft: #d4f2ee;
      --warn: #92400e;
      --warn-soft: #fef3c7;
      --danger: #991b1b;
      --danger-soft: #fee2e2;
      --card: #f8fafc;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      padding: 1rem;
      background: var(--bg);
      color: var(--ink);
      font-family: Georgia, "Iowan Old Style", "Palatino Linotype", serif;
      line-height: 1.36;
    }
    main {
      max-width: 80rem;
      margin: 0 auto;
      background: var(--paper);
      border: 1px solid var(--line);
    }
    header {
      padding: 1.4rem 1.6rem 1.2rem;
      border-bottom: 1px solid var(--line);
      background: #fff;
    }
    h1, h2, h3 { margin: 0; line-height: 1.16; }
    h1 { font-size: 2rem; }
    h2 { font-size: 1.2rem; margin-bottom: 0.7rem; }
    h3 { font-size: 1.02rem; }
    p { margin: 0.45rem 0 0; }
    .lede { max-width: 60rem; color: var(--muted); }
    .meta { color: var(--muted); margin-top: 0.3rem; }
    section { padding: 1rem 1.6rem 1.2rem; border-top: 1px solid var(--line); }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
      gap: 0.55rem;
      margin-top: 0.8rem;
    }
    .card {
      padding: 0.7rem 0.8rem;
      border: 1px solid var(--line);
      background: var(--card);
    }
    .label {
      font-size: 0.78rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .value {
      font-size: 1.08rem;
      font-weight: 700;
      margin-top: 0.12rem;
    }
    .synthesis {
      border: 1px solid var(--line);
      background: linear-gradient(180deg, rgba(255,255,255,1), rgba(212,242,238,0.55));
      padding: 0.95rem 1rem;
    }
    .finding-list, .status-list {
      margin: 0.6rem 0 0;
      padding-left: 1.1rem;
    }
    .index-table, .people-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 0.5rem;
      font-size: 0.95rem;
    }
    th, td {
      border-bottom: 1px solid var(--line);
      padding: 0.45rem 0.45rem;
      text-align: left;
      vertical-align: top;
    }
    th {
      color: var(--muted);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .summary-link {
      color: inherit;
      text-decoration: none;
      border-bottom: 1px dotted var(--accent);
    }
    .summary-link:hover { color: var(--accent); }
    .chips {
      color: var(--muted);
      font-size: 0.89rem;
    }
    .dense { margin-top: 0.25rem; }
    .warn, .danger {
      border: 1px solid var(--line);
      padding: 0.8rem 0.9rem;
    }
    .warn {
      background: var(--warn-soft);
      border-color: #fcd34d;
    }
    .danger {
      background: var(--danger-soft);
      border-color: #fca5a5;
    }
    .empty { color: var(--muted); }
    .evidence-list {
      display: grid;
      gap: 0.8rem;
      margin-top: 0.8rem;
    }
    .evidence-card {
      border: 1px solid var(--line);
      padding: 0.9rem 1rem;
      scroll-margin-top: 1rem;
    }
    .eyebrow {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      margin-bottom: 0.55rem;
    }
    .pill {
      display: inline-block;
      padding: 0.16rem 0.45rem;
      border: 1px solid var(--line);
      background: #fff;
      font-size: 0.8rem;
      color: var(--muted);
    }
    .date-pill {
      border-color: #99f6e4;
      background: var(--accent-soft);
      color: #134e4a;
    }
    .evidence-text {
      margin-top: 0.35rem;
      font-size: 1rem;
    }
    .document-summary {
      margin-top: 0.6rem;
      padding-top: 0.55rem;
      border-top: 1px solid var(--line);
    }
    .meta-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
      gap: 0.35rem 0.8rem;
      margin-top: 0.55rem;
      font-size: 0.92rem;
    }
    .meta-grid > div {
      min-width: 0;
      overflow-wrap: anywhere;
      word-break: break-word;
    }
    .meta-grid a,
    .meta-grid .chips {
      overflow-wrap: anywhere;
      word-break: break-word;
    }
    .disclosure-cell {
      width: 2rem;
      padding-right: 0;
    }
    .disclosure {
      border: none;
      background: transparent;
      padding: 0;
      margin: 0;
      font: inherit;
      color: var(--accent);
      cursor: pointer;
    }
    .triangle {
      display: inline-block;
      width: 1rem;
      text-align: center;
      font-size: 0.95rem;
    }
    .mention-list {
      display: grid;
      gap: 0.35rem;
      padding: 0.15rem 0 0.15rem 0.2rem;
    }
    .mention-line {
      font-size: 0.92rem;
    }
    code { font-size: 0.92em; }
    a { color: var(--accent); }
    @media (max-width: 900px) {
      body { padding: 0.4rem; }
      header, section { padding-left: 0.9rem; padding-right: 0.9rem; }
      .index-table, .people-table, thead, tbody, th, td, tr { display: block; }
      .index-table thead, .people-table thead { display: none; }
      .index-table tr, .people-table tr {
        border: 1px solid var(--line);
        margin-bottom: 0.55rem;
      }
      .index-table td, .people-table td { border-bottom: 1px solid var(--line); }
      .index-table td:last-child, .people-table td:last-child { border-bottom: none; }
      .disclosure-cell { width: auto; padding-right: 0.45rem; }
    }
  </style>
</head>
<body>
  <main>
    <header>
      <h1>{{ title }}</h1>
      <p class="meta">Question: {{ question }}</p>
      {% if run_summary %}
      <p class="meta">Last run: {{ run_summary.started_at }}{% if run_summary.completed_at %} to {{ run_summary.completed_at }}{% endif %}</p>
      {% endif %}
      <p class="lede">This report lists responsive evidence chronologically, using the earliest date detected in each response. The copied PDFs directory contains only responsive source documents referenced by this report.</p>
    </header>

    <section>
      <h2>Run Summary</h2>
      <div class="grid">
        <div class="card"><div class="label">Documents</div><div class="value">{{ "{:,}".format(summary.total_documents) }}</div></div>
        <div class="card"><div class="label">Pages Scanned</div><div class="value">{{ "{:,}".format(summary.total_pages_scanned) }}</div></div>
        <div class="card"><div class="label">Responsive PDFs</div><div class="value">{{ "{:,}".format(summary.responsive_documents) }}</div></div>
        <div class="card"><div class="label">Evidence Rows</div><div class="value">{{ "{:,}".format(summary.responsive_evidence_rows) }}</div></div>
        <div class="card"><div class="label">Errors</div><div class="value">{{ summary.errors_label }}</div></div>
        {% if run_summary %}
        {% if run_summary.pricing_available %}
        <div class="card"><div class="label">Cost</div><div class="value">${{ '%.4f'|format(run_summary.total_cost_usd) }}</div></div>
        {% endif %}
        <div class="card"><div class="label">Prompt Tokens</div><div class="value">{{ "{:,}".format(run_summary.prompt_tokens) }}</div></div>
        <div class="card"><div class="label">Output Tokens</div><div class="value">{{ "{:,}".format(run_summary.candidate_tokens) }}</div></div>
        {% endif %}
      </div>
    </section>

    <section>
      <h2>Project Answer</h2>
      {% if synthesis %}
      <div class="synthesis">
        <p>{{ synthesis.answer }}</p>
        {% if synthesis.key_findings %}
        <ul class="finding-list">
          {% for finding in synthesis.key_findings %}
          <li>{{ finding }}</li>
          {% endfor %}
        </ul>
        {% endif %}
        <p class="chips dense">
          {% if synthesis.people %}<strong>People:</strong> {{ synthesis.people | join("; ") }}{% endif %}
          {% if synthesis.places %} {% if synthesis.people %}|{% endif %} <strong>Places:</strong> {{ synthesis.places | join("; ") }}{% endif %}
          {% if synthesis.dates %} {% if synthesis.people or synthesis.places %}|{% endif %} <strong>Dates:</strong> {{ synthesis.dates | join("; ") }}{% endif %}
        </p>
      </div>
      {% else %}
      <p class="empty">No project-level synthesis is currently stored for this query.</p>
      {% endif %}
    </section>

    <section>
      <h2>Responsive Index</h2>
      {% if evidence_rows %}
      <table class="index-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Key Person</th>
            <th>Brief Summary</th>
          </tr>
        </thead>
        <tbody>
          {% for row in evidence_rows %}
          <tr>
            <td>{{ row.date_badge_label }}</td>
            <td>{{ row.key_person }}</td>
            <td><a class="summary-link" href="#{{ row.anchor }}">{{ row.brief_summary }}</a></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p class="empty">No responsive evidence rows are currently available.</p>
      {% endif %}
    </section>

    <section>
      <h2>People</h2>
      <p class="meta">Authoritative names are clustered automatically and sorted by last name. Expand a row to see each matching extracted form in context.</p>
      {% if people_index %}
      <table class="people-table">
        <thead>
          <tr>
            <th></th>
            <th>Person</th>
            <th>Mentions</th>
            <th>Time Period</th>
          </tr>
        </thead>
        <tbody>
          {% for person in people_index %}
          <tr>
            <td class="disclosure-cell">
              <button class="disclosure" type="button" data-toggle-target="{{ person.toggle_id }}" aria-expanded="false" aria-controls="{{ person.toggle_id }}">
                <span class="triangle">▸</span>
              </button>
            </td>
            <td>{{ person.person }}</td>
            <td>{{ "{:,}".format(person.mention_count) }}</td>
            <td>{{ person.time_period }}</td>
          </tr>
          <tr id="{{ person.toggle_id }}" hidden>
            <td colspan="4">
              <div class="mention-list">
                {% for mention in person.mentions %}
                <div class="mention-line">
                  <a href="#{{ mention.anchor }}">{{ mention.date_badge_label }}</a> | {{ mention.brief_summary }}
                  <span class="chips">({{ mention.source_filename }}{% if mention.page_label %}, {% if mention.page_href %}<a href="{{ mention.page_href }}" target="_blank" rel="noopener noreferrer">{{ mention.page_label }}</a>{% else %}{{ mention.page_label }}{% endif %}{% endif %}; matched as {{ mention.matched_names | join("; ") }})</span>
                </div>
                {% endfor %}
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p class="empty">No named people were extracted from the responsive evidence.</p>
      {% endif %}
    </section>

    <section>
      <h2>Responsive Evidence Timeline</h2>
      <p class="meta">Each filename links to its entry in the Responsive Documents section.</p>
      {% if evidence_rows %}
      <div class="evidence-list">
        {% for row in evidence_rows %}
        <article class="evidence-card" id="{{ row.anchor }}">
          <div class="eyebrow">
            <span class="pill date-pill">{{ row.date_badge_label }}</span>
            <span class="pill">{{ row.key_person }}</span>
            {% if row.page_label %}{% if row.page_href %}<a class="pill" href="{{ row.page_href }}" target="_blank" rel="noopener noreferrer">{{ row.page_label }}</a>{% else %}<span class="pill">{{ row.page_label }}</span>{% endif %}{% endif %}
            <span class="pill">Score {% if row.relevance_score is not none %}{{ row.relevance_score }}/10{% else %}?{% endif %}</span>
          </div>
          <h3>{{ row.brief_summary }}</h3>
          <p class="evidence-text">{{ row.summary }}</p>
          <div class="meta-grid">
            <div>
              <strong>File:</strong>
              {% if row.document_anchor %}
              <a href="#{{ row.document_anchor }}">{{ row.source_filename }}</a>
              {% else %}
              {{ row.source_filename }}
              {% endif %}
            </div>
            {% if row.people %}
            <div><strong>People:</strong> {{ row.people | join("; ") }}</div>
            {% endif %}
          </div>
        </article>
        {% endfor %}
      </div>
      {% else %}
      <p class="empty">No responsive evidence rows are currently available.</p>
      {% endif %}
    </section>

    <section>
      <h2>Responsive Documents</h2>
      {% if responsive_documents_index %}
      <table class="people-table">
        <thead>
          <tr>
            <th></th>
            <th>Filename</th>
            <th>Pages</th>
            <th>Summary</th>
          </tr>
        </thead>
        <tbody>
          {% for document in responsive_documents_index %}
          <tr id="{{ document.anchor }}">
            <td class="disclosure-cell">
              <button class="disclosure" type="button" data-toggle-target="doc-{{ document.anchor }}" aria-expanded="false" aria-controls="doc-{{ document.anchor }}">
                <span class="triangle">▸</span>
              </button>
            </td>
            <td>
              {% if document.report_href %}
              <a href="{{ document.report_href }}">{{ document.source_filename }}</a>
              {% else %}
              {{ document.source_filename }}
              {% endif %}
            </td>
            <td>{{ "{:,}".format(document.page_count) }}</td>
            <td>{{ document.document_summary }}</td>
          </tr>
          <tr id="doc-{{ document.anchor }}" hidden>
            <td colspan="4">
              <div class="mention-list">
                {% for item in document.evidence_items %}
                <div class="mention-line">
                  <a href="#{{ item.anchor }}">{{ item.brief_summary }}</a>
                  <span class="chips">(
                    {% if item.page_href %}<a href="{{ item.page_href }}" target="_blank" rel="noopener noreferrer">{{ item.page_label }}</a>{% else %}{{ item.page_label }}{% endif %}
                    {% if item.people %} | {{ item.people | join("; ") }}{% endif %}
                  )</span>
                </div>
                {% endfor %}
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p class="empty">No responsive documents are currently available.</p>
      {% endif %}
    </section>

    <section>
      <h2>Errors</h2>
      {% if failure_rows or unanalyzed_rows %}
      {% if failure_rows %}
      <div class="danger">
        <p><strong>{{ "{:,}".format(failure_rows|length) }}</strong> failure{% if failure_rows|length != 1 %}s{% endif %}</p>
        <ul class="status-list">
          {% for row in failure_rows %}
          <li><strong>{{ row.source_filename }}</strong> | {{ row.failure_type or row.status }}{% if row.error_text %}: {{ row.error_text }}{% endif %}</li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
      {% if unanalyzed_rows %}
      <div class="warn">
        <p><strong>{{ "{:,}".format(unanalyzed_rows|length) }}</strong> unanalyzed</p>
        <ul class="status-list">
          {% for row in unanalyzed_rows %}
          <li><strong>{{ row.canonical_filename }}</strong> | {{ row.status or "not yet analyzed" }}{% if row.failure_type %} ({{ row.failure_type }}){% endif %}{% if row.error_text %}: {{ row.error_text }}{% endif %}</li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}
      {% else %}
      <p class="empty">none</p>
      {% endif %}
    </section>
  </main>
  <script>
    document.querySelectorAll("[data-toggle-target]").forEach((button) => {
      button.addEventListener("click", () => {
        const target = document.getElementById(button.dataset.toggleTarget);
        if (!target) {
          return;
        }
        const expanded = button.getAttribute("aria-expanded") === "true";
        button.setAttribute("aria-expanded", expanded ? "false" : "true");
        const triangle = button.querySelector(".triangle");
        if (triangle) {
          triangle.textContent = expanded ? "▸" : "▾";
        }
        target.hidden = expanded;
      });
    });
  </script>
</body>
</html>
