<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  <style>
    :root {
      color-scheme: light;
      --paper: #fcfcfd;
      --bg: #e5e7eb;
      --ink: #1f2937;
      --muted: #6b7280;
      --line: #c7ccd4;
      --accent: #0f766e;
      --accent-soft: #d4f2ee;
      --warn: #92400e;
      --warn-soft: #fef3c7;
      --danger: #991b1b;
      --danger-soft: #fee2e2;
      --panel: rgba(15, 118, 110, 0.08);
      --panel-white: rgba(255, 255, 255, 0.9);
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      padding: 2rem;
      background:
        radial-gradient(circle at top left, rgba(15, 118, 110, 0.14), transparent 28rem),
        linear-gradient(180deg, #f3f4f6 0%, #dfe3e8 100%);
      color: var(--ink);
      font-family: Georgia, "Iowan Old Style", "Palatino Linotype", serif;
      line-height: 1.45;
    }
    main {
      max-width: 84rem;
      margin: 0 auto;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 18px 40px rgba(31, 41, 55, 0.10);
    }
    header {
      padding: 2.5rem;
      border-bottom: 1px solid var(--line);
      background: linear-gradient(135deg, rgba(15, 118, 110, 0.12), rgba(255, 255, 255, 0));
    }
    h1, h2, h3 { margin: 0; line-height: 1.2; }
    h2 { font-size: 1.3rem; margin-bottom: 0.85rem; }
    .lede { margin-top: 1rem; max-width: 56rem; color: var(--muted); }
    .meta { color: var(--muted); margin-top: 0.35rem; }
    section { padding: 1.5rem 2rem 2rem; border-top: 1px solid var(--line); }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
      gap: 0.75rem;
      margin-top: 1rem;
    }
    .card {
      padding: 0.9rem 1rem;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--panel-white);
    }
    .label { font-size: 0.85rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; }
    .value { font-size: 1.2rem; font-weight: 700; margin-top: 0.2rem; }
    .synthesis {
      border: 1px solid var(--line);
      border-radius: 14px;
      background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(212,242,238,0.4));
      padding: 1rem 1.1rem;
    }
    .finding-list, .status-list { margin: 0.75rem 0 0; padding-left: 1.2rem; }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
      font-size: 0.96rem;
    }
    th, td {
      border-bottom: 1px solid var(--line);
      padding: 0.8rem 0.65rem;
      text-align: left;
      vertical-align: top;
    }
    th {
      color: var(--muted);
      font-size: 0.83rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .chips { color: var(--muted); font-size: 0.92rem; }
    .warn {
      background: var(--warn-soft);
      border: 1px solid #fcd34d;
      border-radius: 12px;
      padding: 0.9rem 1rem;
    }
    .danger {
      background: var(--danger-soft);
      border: 1px solid #fca5a5;
      border-radius: 12px;
      padding: 0.9rem 1rem;
    }
    .empty { color: var(--muted); }
    code { font-size: 0.92em; }
    a { color: var(--accent); }
    @media (max-width: 900px) {
      body { padding: 1rem; }
      header, section { padding-left: 1.2rem; padding-right: 1.2rem; }
      table, thead, tbody, th, td, tr { display: block; }
      thead { display: none; }
      tr {
        border: 1px solid var(--line);
        border-radius: 12px;
        margin-bottom: 0.9rem;
        overflow: hidden;
        background: white;
      }
      td { border-bottom: 1px solid var(--line); }
      td:last-child { border-bottom: none; }
    }
  </style>
</head>
<body>
  <main>
    <header>
      <h1>{{ title }}</h1>
      <p class="meta">Question: {{ question }}</p>
      {% if run_summary %}
      <p class="meta">Last run: {{ run_summary.started_at }}{% if run_summary.completed_at %} to {{ run_summary.completed_at }}{% endif %}</p>
      {% endif %}
      <p class="lede">This report shows one row per responsive evidence item, grouped from per-document Gemini analyses over the configured PDF archive. Evidence is sorted by the earliest detected year in the extracted dates or summary text.</p>
    </header>

    <section>
      <h2>Run Summary</h2>
      <div class="grid">
        <div class="card"><div class="label">Documents</div><div class="value">{{ summary.total_documents }}</div></div>
        <div class="card"><div class="label">Responsive Documents</div><div class="value">{{ summary.responsive_documents }}</div></div>
        <div class="card"><div class="label">Evidence Rows</div><div class="value">{{ summary.responsive_evidence_rows }}</div></div>
        <div class="card"><div class="label">Failures</div><div class="value">{{ summary.failed_documents }}</div></div>
        <div class="card"><div class="label">Unanalyzed</div><div class="value">{{ summary.unanalyzed_documents }}</div></div>
        {% if run_summary %}
        <div class="card"><div class="label">Run Cost</div><div class="value">${{ '%.4f'|format(run_summary.total_cost_usd) }}</div></div>
        <div class="card"><div class="label">Prompt Tokens</div><div class="value">{{ run_summary.prompt_tokens }}</div></div>
        <div class="card"><div class="label">Output Tokens</div><div class="value">{{ run_summary.candidate_tokens }}</div></div>
        <div class="card"><div class="label">Uploads</div><div class="value">{{ run_summary.upload_count }}</div></div>
        {% endif %}
      </div>
    </section>

    <section>
      <h2>Project Answer</h2>
      {% if synthesis %}
      <div class="synthesis">
        <p>{{ synthesis.answer }}</p>
        {% if synthesis.key_findings %}
        <ul class="finding-list">
          {% for finding in synthesis.key_findings %}
          <li>{{ finding }}</li>
          {% endfor %}
        </ul>
        {% endif %}
        <p class="chips">
          {% if synthesis.people %}<strong>People:</strong> {{ synthesis.people | join("; ") }}{% endif %}
          {% if synthesis.places %} {% if synthesis.people %}|{% endif %} <strong>Places:</strong> {{ synthesis.places | join("; ") }}{% endif %}
          {% if synthesis.dates %} {% if synthesis.people or synthesis.places %}|{% endif %} <strong>Dates:</strong> {{ synthesis.dates | join("; ") }}{% endif %}
        </p>
      </div>
      {% else %}
      <p class="empty">No project-level synthesis is currently stored for this query.</p>
      {% endif %}
    </section>

    <section>
      <h2>Responsive Evidence</h2>
      {% if evidence_rows %}
      <table>
        <thead>
          <tr>
            <th>File</th>
            <th>Page</th>
            <th>Evidence</th>
            <th>People / Places / Dates</th>
            <th>Document Summary</th>
            <th>Score</th>
          </tr>
        </thead>
        <tbody>
          {% for row in evidence_rows %}
          <tr>
            <td>
              {% if row.report_href %}
              <a href="{{ row.report_href }}">{{ row.source_filename }}</a>
              {% else %}
              {{ row.source_filename }}
              {% endif %}
              <div class="chips">{{ row.source_path }}</div>
            </td>
            <td>{% if row.page_number %}{{ row.page_number }}{% else %}Unknown{% endif %}</td>
            <td>{{ row.summary }}</td>
            <td class="chips">
              {% if row.people %}<strong>People:</strong> {{ row.people | join("; ") }}<br>{% endif %}
              {% if row.places %}<strong>Places:</strong> {{ row.places | join("; ") }}<br>{% endif %}
              {% if row.dates %}<strong>Dates:</strong> {{ row.dates | join("; ") }}{% endif %}
            </td>
            <td>{{ row.document_summary }}</td>
            <td>{% if row.relevance_score is not none %}{{ row.relevance_score }}/10{% else %}?{% endif %}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p class="empty">No responsive evidence rows are currently available.</p>
      {% endif %}
    </section>

    <section>
      <h2>Unanalyzed PDFs</h2>
      {% if unanalyzed_rows %}
      <div class="warn">
        <ul class="status-list">
          {% for row in unanalyzed_rows %}
          <li><strong>{{ row.canonical_filename }}</strong> — {{ row.status or "not yet analyzed" }}{% if row.failure_type %} ({{ row.failure_type }}){% endif %}{% if row.error_text %}: {{ row.error_text }}{% endif %}</li>
          {% endfor %}
        </ul>
      </div>
      {% else %}
      <p class="empty">All discovered PDFs for this project have stored successful analyses for the active query.</p>
      {% endif %}
    </section>

    <section>
      <h2>Failures</h2>
      {% if failure_rows %}
      <div class="danger">
        <ul class="status-list">
          {% for row in failure_rows %}
          <li><strong>{{ row.source_filename }}</strong> — {{ row.failure_type or row.status }}{% if row.error_text %}: {{ row.error_text }}{% endif %}</li>
          {% endfor %}
        </ul>
      </div>
      {% else %}
      <p class="empty">No failed analyses are currently recorded for this query.</p>
      {% endif %}
    </section>
  </main>
</body>
</html>
